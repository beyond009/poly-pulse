PORT=3939
PMXT_API_URL=http://localhost:3847
PMXT_ACCESS_TOKEN=my-token
CACHE_TTL_SECONDS=30

# xAPI (xapi.to) - X/Twitter data for social heat & sentiment
# Get a key via: npx xapi-to register  (then copy the sk-... key)
XAPI_KEY=sk-xxx
# Optional: override action host (default action.xapi.to)
# XAPI_ACTION_HOST=action.xapi.to

# Proxy (required if your network needs it to reach external APIs)
# https_proxy=http://127.0.0.1:7890
# http_proxy=http://127.0.0.1:7890
